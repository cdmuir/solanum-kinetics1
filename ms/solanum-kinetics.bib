              osca1-2
              /
              1.3
              /
              2.2
              /
              2.3
              /
              3.1
              Ca
              2+
              -permeable channel quintuple,
              osca1.3
              /
              1.7
              -channel double,
              cngc5
              /
              6
              -channel double,
