@article{woning_revisiting_2026,
  title = {Revisiting the Relationship between Stomatal Size and Speed across Species -- a Meta-Analysis},
  author = {Woning, Nik and {Al-Salman}, Yazen and Kaiser, Elias and Berman, Sarah R. and Brendel, Oliver and Cano, Francisco Javier and Carpentier, Sebastien and Centritto, Mauro and Drake, Paul L. and Durand, Maxime and Eyland, David and Franks, Peter J. and Gerardin, Theo and Ghannoum, Oula and Haworth, Matthew and K{\"u}barsepp, Liisa and Lawson, Tracy and Le Thiec, Didier and Li, Yong and Marcelis, Leo F. M. and Marino, Giovanni and McAusland, Lorna and Muir, Christopher D. and Niinemets, {\"U}lo and Nunes, Tiago D. G. and Raissig, Michael T. and Sakoda, Kazuma and Sugiura, Daisuke and Tosens, Tiina and Zhang, Qiangqiang and Zhang, Ningyi and {Vialet-Chabrand}, Silvere},
  year = 2026,
  month = mar,
  journal = {New Phytologist},
  volume = {249},
  number = {5},
  pages = {2338--2354},
  issn = {0028-646X, 1469-8137},
  doi = {10.1111/nph.70842},
  urldate = {2026-04-01},
  abstract = {Summary                                                                                     The rate of stomatal opening and closure in response to changes in light affects leaf photosynthesis and water use. However, it is unclear how strongly stomatal size (                     SS                     ) and density (                     SD                     ) influence stomatal conductance (                     g                     s                     ) kinetics, and whether variation arises from methodological differences, guard cell type or degree of amphistomaty.                                                                                             We divided published records combining stomatal kinetics and anatomical traits from 89 species into kidney and dumbbell-shaped guard cells, and evaluated four dynamic                     g                     s                     models on them. We derived the time constant for an exponential response of                     g                     s                     (                     {$\tau$}                     ) and the maximum rate of change (                     Sl                     max                     ) as well as the ratio of adaxial/abaxial                     SD                     (                     rSD                     ).                                                                                             We found significant differences in parameter estimation between models. Stomatal anatomical traits and kinetic parameters showed large variation across species. While individual anatomical features (                     SS                     ,                     SD                     ,                     rSD                     and guard cell types) were weakly correlated with stomatal response speed (                     {$\tau$}                     and                     Sl                     max                     ), interactions between these features showed significant effects, demonstrating that kinetic performance arises from synergistic rather than additive anatomical relationships.                                                                                             Our results call for the use of our unified modeling approach, challenge the generality of the observation that smaller stomata move faster across species and suggest                     rSD                     as an understudied driver of stomatal kinetics.},
  langid = {english},
  file = {/Users/cdmuir/Zotero/storage/NMBP923V/Woning et al. - 2026 - Revisiting the relationship between stomatal size and speed across species – a meta-analysis.pdf}
}

